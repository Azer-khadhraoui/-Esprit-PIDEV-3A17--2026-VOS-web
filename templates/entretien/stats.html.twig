{% extends 'base.html.twig' %}
{% block title %}Statistiques{% endblock %}

{% block body %}

<h1>Statistiques</h1>
<p class="subtitle">Tableau de bord analytique — Entretiens & Évaluations</p>

{# ── FILTRE PANEL ── #}
<div style="background:white;border-radius:14px;padding:20px 24px;margin-bottom:24px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px">
        <i class="fas fa-sliders-h" style="color:#4361ee"></i>
        <span style="font-weight:700;font-size:0.95rem;color:#1a1a2e">Filtrer les statistiques</span>
    </div>

    {# Raccourcis période #}
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
        {% set periodes = [
            {'val': '',    'label': 'Tout'},
            {'val': '7j',  'label': '7 derniers jours'},
            {'val': '30j', 'label': '30 derniers jours'},
            {'val': '3m',  'label': '3 mois'},
            {'val': '6m',  'label': '6 mois'},
            {'val': '1an', 'label': '1 an'},
        ] %}
        {% for p in periodes %}
        <a href="{{ path('app_entretien_stats', {periode: p.val, type: typeFilter}) }}"
           style="padding:6px 14px;border-radius:20px;font-size:0.82rem;font-weight:600;text-decoration:none;border:1.5px solid {{ periode == p.val ? '#4361ee' : '#e0e6ed' }};background:{{ periode == p.val ? '#4361ee' : 'white' }};color:{{ periode == p.val ? 'white' : '#6c757d' }};transition:all 0.2s">
            {{ p.label }}
        </a>
        {% endfor %}
    </div>

    {# Formulaire filtres avancés #}
    <form method="get" action="{{ path('app_entretien_stats') }}">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label style="font-size:0.82rem;font-weight:600;color:#495057">Date début</label>
                <input type="date" name="dateDebut" value="{{ dateDebut }}" class="form-control">
            </div>
            <div class="col-md-3">
                <label style="font-size:0.82rem;font-weight:600;color:#495057">Date fin</label>
                <input type="date" name="dateFin" value="{{ dateFin }}" class="form-control">
            </div>
            <div class="col-md-3">
                <label style="font-size:0.82rem;font-weight:600;color:#495057">Type d'entretien</label>
                <select name="type" class="form-select">
                    <option value="">Tous les types</option>
                    <option value="RH"        {% if typeFilter == 'RH' %}selected{% endif %}>RH</option>
                    <option value="TECHNIQUE" {% if typeFilter == 'TECHNIQUE' %}selected{% endif %}>TECHNIQUE</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" style="background:#4361ee;color:white;border:none;padding:9px 20px;border-radius:9px;font-weight:600;font-size:0.88rem;display:flex;align-items:center;gap:6px">
                    <i class="fas fa-search"></i> Appliquer
                </button>
                <a href="{{ path('app_entretien_stats') }}"
                   style="background:#f0f2f5;color:#6c757d;border:none;padding:9px 14px;border-radius:9px;font-size:0.88rem;text-decoration:none;display:flex;align-items:center">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </div>
    </form>

    {% if dateDebut or dateFin or typeFilter %}
    <div style="margin-top:12px;padding:8px 14px;background:#f0f4ff;border-radius:8px;font-size:0.82rem;color:#4361ee">
        <i class="fas fa-filter me-1"></i>
        Filtre actif :
        {% if dateDebut %} Du <strong>{{ dateDebut }}</strong>{% endif %}
        {% if dateFin %} au <strong>{{ dateFin }}</strong>{% endif %}
        {% if typeFilter %} · Type : <strong>{{ typeFilter }}</strong>{% endif %}
        · <strong>{{ total }}</strong> entretien(s) trouvé(s)
    </div>
    {% endif %}
</div>

{# ── KPI CARDS ── #}
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div style="background:white;border-radius:14px;padding:20px 22px;border-left:4px solid #4361ee;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                    <div style="color:#8c98a4;font-size:0.82rem;margin-bottom:6px">Total Entretiens</div>
                    <div style="font-size:2rem;font-weight:800;color:#1a1a2e">{{ total }}</div>
                </div>
                <div style="background:#eef1ff;width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center">
                    <i class="fas fa-briefcase" style="color:#4361ee"></i>
                </div>
            </div>
            <div style="margin-top:10px;font-size:0.78rem;color:#8c98a4">
                <span style="color:#06d6a0;font-weight:600">{{ termines }}</span> terminés ·
                <span style="color:#4361ee;font-weight:600">{{ planifies }}</span> planifiés
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div style="background:white;border-radius:14px;padding:20px 22px;border-left:4px solid #06d6a0;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                    <div style="color:#8c98a4;font-size:0.82rem;margin-bottom:6px">Taux de réussite</div>
                    <div style="font-size:2rem;font-weight:800;color:#1a1a2e">{{ tauxReussite }}%</div>
                </div>
                <div style="background:#e8fdf5;width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center">
                    <i class="fas fa-trophy" style="color:#06d6a0"></i>
                </div>
            </div>
            <div style="margin-top:10px">
                <div style="height:5px;background:#f0f2f5;border-radius:3px;overflow:hidden">
                    <div style="width:{{ tauxReussite }}%;height:100%;background:#06d6a0;border-radius:3px"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div style="background:white;border-radius:14px;padding:20px 22px;border-left:4px solid #fb8500;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                    <div style="color:#8c98a4;font-size:0.82rem;margin-bottom:6px">Score Moyen</div>
                    <div style="font-size:2rem;font-weight:800;color:#1a1a2e">{{ scoreMoyen }}<span style="font-size:1rem;color:#8c98a4">/100</span></div>
                </div>
                <div style="background:#fff5e6;width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center">
                    <i class="fas fa-chart-line" style="color:#fb8500"></i>
                </div>
            </div>
            <div style="margin-top:10px;font-size:0.78rem;color:#8c98a4">
                Note moyenne : <span style="color:#fb8500;font-weight:600">{{ noteMoyenne }}/5</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div style="background:white;border-radius:14px;padding:20px 22px;border-left:4px solid #7209b7;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                    <div style="color:#8c98a4;font-size:0.82rem;margin-bottom:6px">Évaluations</div>
                    <div style="font-size:2rem;font-weight:800;color:#1a1a2e">{{ totalEvals }}</div>
                </div>
                <div style="background:#f5e6ff;width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center">
                    <i class="fas fa-star" style="color:#7209b7"></i>
                </div>
            </div>
            <div style="margin-top:10px;font-size:0.78rem;color:#8c98a4">
                <span style="color:#06d6a0;font-weight:600">{{ nbAcceptes }}</span> acc. ·
                <span style="color:#f72585;font-weight:600">{{ nbRefuses }}</span> ref. ·
                <span style="color:#fb8500;font-weight:600">{{ nbEnAttente }}</span> att.
            </div>
        </div>
    </div>
</div>

{# ── MINI KPI ROW ── #}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div style="background:white;border-radius:12px;padding:16px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 8px rgba(0,0,0,0.05)">
            <div style="background:#e8f4fd;width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="fas fa-user-tie" style="color:#1565c0;font-size:1.1rem"></i>
            </div>
            <div>
                <div style="font-size:0.8rem;color:#8c98a4">Entretiens RH</div>
                <div style="font-size:1.5rem;font-weight:800;color:#1565c0">{{ nbRH }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div style="background:white;border-radius:12px;padding:16px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 8px rgba(0,0,0,0.05)">
            <div style="background:#f3e5f5;width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="fas fa-laptop-code" style="color:#6a1b9a;font-size:1.1rem"></i>
            </div>
            <div>
                <div style="font-size:0.8rem;color:#8c98a4">Entretiens Techniques</div>
                <div style="font-size:1.5rem;font-weight:800;color:#6a1b9a">{{ nbTechnique }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div style="background:white;border-radius:12px;padding:16px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 8px rgba(0,0,0,0.05)">
            <div style="background:#fde8e8;width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="fas fa-times-circle" style="color:#c0392b;font-size:1.1rem"></i>
            </div>
            <div>
                <div style="font-size:0.8rem;color:#8c98a4">Autres / Annulés</div>
                <div style="font-size:1.5rem;font-weight:800;color:#c0392b">{{ autres }}</div>
            </div>
        </div>
    </div>
</div>

{# ── CHARTS ROW 1 ── #}
<div class="row g-3 mb-3">
    <div class="col-md-5">
        <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px">Entretiens par Statut</div>
            <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:16px">Répartition selon le statut</div>
            <canvas id="chartStatut" height="200"></canvas>
        </div>
    </div>
    <div class="col-md-4">
        <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px">Entretiens par Type</div>
            <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:16px">RH vs Technique</div>
            <canvas id="chartType" height="200"></canvas>
        </div>
    </div>
    <div class="col-md-3">
        <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px">Décisions</div>
            <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:16px">Résultats évaluations</div>
            <canvas id="chartDecision" height="200"></canvas>
        </div>
    </div>
</div>

{# ── CHARTS ROW 2 ── #}
<div class="row g-3">
    {% if parMoisLabels|length > 0 %}
    <div class="col-md-7">
        <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px">Évolution par mois</div>
            <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:16px">Nombre d'entretiens par mois</div>
            <canvas id="chartMois" height="120"></canvas>
        </div>
    </div>
    {% endif %}
    {% if evalStats is defined and evalStats %}
    <div class="{{ parMoisLabels|length > 0 ? 'col-md-5' : 'col-12' }}">
        <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.06)">
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px">Compétences moyennes</div>
            <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:16px">Grille d'évaluation /5</div>
            <canvas id="chartCompetences" height="180"></canvas>
        </div>
    </div>
    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.font.family = "'Segoe UI', sans-serif";
Chart.defaults.color = '#8c98a4';

// Chart Statut
new Chart(document.getElementById('chartStatut'), {
    type: 'doughnut',
    data: {
        labels: {{ parStatutLabels|json_encode|raw }},
        datasets: [{ data: {{ parStatutData|json_encode|raw }}, backgroundColor: ['#4361ee','#06d6a0','#fb8500','#f72585','#7209b7'], borderWidth: 3, borderColor: '#fff' }]
    },
    options: { plugins: { legend: { position: 'bottom', labels: { padding: 14, font: { size: 11 } } } }, cutout: '65%' }
});

// Chart Type
new Chart(document.getElementById('chartType'), {
    type: 'doughnut',
    data: {
        labels: {{ parTypeLabels|json_encode|raw }},
        datasets: [{ data: {{ parTypeData|json_encode|raw }}, backgroundColor: ['#1565c0','#6a1b9a','#fb8500'], borderWidth: 3, borderColor: '#fff' }]
    },
    options: { plugins: { legend: { position: 'bottom', labels: { padding: 14, font: { size: 11 } } } }, cutout: '65%' }
});

// Chart Décisions
new Chart(document.getElementById('chartDecision'), {
    type: 'doughnut',
    data: {
        labels: ['Acceptés', 'Refusés', 'En attente'],
        datasets: [{ data: [{{ nbAcceptes }}, {{ nbRefuses }}, {{ nbEnAttente }}], backgroundColor: ['#06d6a0','#f72585','#fb8500'], borderWidth: 3, borderColor: '#fff' }]
    },
    options: { plugins: { legend: { position: 'bottom', labels: { padding: 14, font: { size: 11 } } } }, cutout: '65%' }
});

{% if parMoisLabels|length > 0 %}
// Chart par mois
new Chart(document.getElementById('chartMois'), {
    type: 'bar',
    data: {
        labels: {{ parMoisLabels|json_encode|raw }},
        datasets: [{
            label: 'Entretiens',
            data: {{ parMoisData|json_encode|raw }},
            backgroundColor: 'rgba(67,97,238,0.15)',
            borderColor: '#4361ee',
            borderWidth: 2,
            borderRadius: 8,
            fill: true
        }]
    },
    options: {
        scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } },
            x: { grid: { display: false } }
        },
        plugins: { legend: { display: false } }
    }
});
{% endif %}

{% if evalStats is defined and evalStats %}
// Chart Compétences
new Chart(document.getElementById('chartCompetences'), {
    type: 'radar',
    data: {
        labels: ['Tech.','Comport.','Comm.','Motiv.','Exp.'],
        datasets: [{
            label: 'Moyenne /5',
            data: {{ evalStats|json_encode|raw }},
            backgroundColor: 'rgba(67,97,238,0.15)',
            borderColor: '#4361ee',
            borderWidth: 2,
            pointBackgroundColor: '#4361ee',
            pointRadius: 4
        }]
    },
    options: {
        scales: { r: { beginAtZero: true, max: 5, ticks: { stepSize: 1 } } },
        plugins: { legend: { display: false } }
    }
});
{% endif %}
</script>
{% endblock %}
