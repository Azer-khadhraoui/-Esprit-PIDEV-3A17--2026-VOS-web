{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Modifier Préférence | VOS Admin{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item" href="{{ path('app_admin_dashboard') }}">Gestion Users</a>
            <a class="nav-item" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item is-active" href="{{ path('app_admin_preferences') }}">Gestion Préférences</a>
            <a class="nav-item" href="#">Gestion Entretiens</a>
            <a class="nav-item" href="#">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
            <a class="nav-item" href="#">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Modifier Préférence</h1>
                <p>Bienvenue {{ adminName }}</p>
            </div>
            <form method="post" action="{{ path('app_logout') }}">
                <button class="btn-logout" type="submit">Déconnexion</button>
            </form>
        </header>

        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}

        <section class="table-card">
            <div class="table-head">
                <h2>Préférence #{{ preference.idPreference }}</h2>
            </div>

            <div class="form-section">
                <form method="POST">
                    <div class="form-group">
                        <label>Utilisateur</label>
                        <p class="form-value">{{ preference.idUtilisateur.nom }} {{ preference.idUtilisateur.prenom }}</p>
                    </div>

                    <div class="form-group">
                        <label for="type_poste">Type de Poste Souhaité</label>
                        <input type="text" id="type_poste" name="type_poste_souhaite" value="{{ preference.typePosteSouhaite ?? '' }}" class="form-input">
                    </div>

                    <div class="form-group">
                        <label for="mode_travail">Mode de Travail</label>
                        <select id="mode_travail" name="mode_travail" class="form-select">
                            <option value="100% Présentiel" {% if preference.modeTravail == '100% Présentiel' %}selected{% endif %}>100% Présentiel</option>
                            <option value="100% Télétravail" {% if preference.modeTravail == '100% Télétravail' %}selected{% endif %}>100% Télétravail</option>
                            <option value="Hybride" {% if preference.modeTravail == 'Hybride' %}selected{% endif %}>Hybride</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="disponibilite">Disponibilité</label>
                        <input type="date" id="disponibilite" name="disponibilite" value="{{ preference.disponibilite|date('Y-m-d') ?? '' }}" class="form-input">
                    </div>

                    <div class="form-group">
                        <label for="mobilite">Mobilité Géographique</label>
                        <input type="text" id="mobilite" name="mobilite_geographique" value="{{ preference.mobiliteGeographique ?? '' }}" class="form-input">
                    </div>

                    <div class="form-group">
                        <label for="deplacement">
                            <input type="checkbox" id="deplacement" name="pret_deplacement" value="1" {% if preference.pretDeplacement %}checked{% endif %}>
                            Prêt au déplacement
                        </label>
                    </div>

                    <div class="form-group">
                        <label for="type_contrat">Type de Contrat Souhaité</label>
                        <input type="text" id="type_contrat" name="type_contrat_souhaite" value="{{ preference.typeContratSouhaite ?? '' }}" class="form-input">
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-save">Enregistrer</button>
                        <a href="{{ path('app_admin_preferences') }}" class="btn-cancel">Annuler</a>
                    </div>
                </form>
            </div>
        </section>
    </main>
</div>

<style>
    .form-section {
        padding: 20px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .form-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        margin-bottom: 8px;
        font-weight: 600;
        color: #8eb9ff;
        font-size: 0.9rem;
    }

    .form-value {
        margin: 0;
        color: #ffffff;
        font-size: 0.95rem;
    }

    .form-input,
    .form-select {
        padding: 10px 12px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px;
        color: #ffffff;
        font-family: 'Poppins', sans-serif;
        font-size: 0.95rem;
    }

    .form-input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .form-input:focus,
    .form-select:focus {
        outline: none;
        border-color: #2156d8;
        background: rgba(33, 86, 216, 0.1);
    }

    .form-select {
        cursor: pointer;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-save,
    .btn-cancel {
        flex: 1;
        padding: 10px 16px;
        border-radius: 8px;
        border: 0;
        cursor: pointer;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
        transition: 0.2s ease;
    }

    .btn-save {
        background: #2156d8;
        color: #fff;
    }

    .btn-save:hover {
        background: #1845b0;
    }

    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }

    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
    }
</style>
{% endblock %}
