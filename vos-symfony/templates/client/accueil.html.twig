{% extends 'base.html.twig' %}

{% block title %}Accueil Client | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: #000;
        }

        .intro-screen {
            position: relative;
            min-height: 100vh;
            width: 100%;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
        }

        .intro-screen .vos-header {
            position: absolute !important;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 50;
            margin: 0;
        }

        .intro-bg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
        }

        .intro-overlay {
            position: absolute;
            inset: 0;
            z-index: 2;
            background:
                radial-gradient(1200px 500px at 22% 10%, rgba(64, 97, 234, 0.28), transparent 42%),
                linear-gradient(180deg, rgba(2, 6, 23, 0.24) 0%, rgba(2, 6, 23, 0.78) 100%);
        }

        .bottom-left-copy {
            position: absolute;
            z-index: 4;
            left: clamp(16px, 5vw, 56px);
            bottom: clamp(14px, 4.5vh, 46px);
            max-width: min(88vw, 860px);
            color: #ffffff;
            text-shadow: 0 10px 22px rgba(0, 0, 0, 0.45);
            pointer-events: none;
        }

        .vos-header {
            position: relative !important;
        }

        .bottom-left-title {
            margin: 0;
            font-family: 'Orbitron', 'Poppins', sans-serif;
            font-size: clamp(1.1rem, 3vw, 2.5rem);
            line-height: 1.08;
            letter-spacing: 0.01em;
            font-weight: 800;
            text-transform: none;
        }

        .bottom-left-text {
            margin: 14px 0 0;
            font-size: clamp(0.72rem, 0.95vw, 0.95rem);
            line-height: 1.35;
            color: rgba(255, 255, 255, 0.95);
            max-width: 62ch;
            font-weight: 500;
        }

        @media (max-width: 780px) {

    </style>
{% endblock %}

{% block body %}
<div class="intro-screen">
    <video class="intro-bg" src="{{ asset('videos/intro.mp4') }}" autoplay muted loop playsinline preload="auto"></video>
    <div class="intro-overlay"></div>

    {% include 'components/vos_header.html.twig' %}

    <div class="bottom-left-copy">
        <h2 class="bottom-left-title">Connectez-vous<br>aux meilleurs développeurs</h2>
        <p class="bottom-left-text">Nous connectons les entreprises aux développeurs les plus qualifiés à travers le globe.</p>
    </div>
</div>
{% endblock %}
